# ============================================
# SecureChat - Environment Variables
# ============================================

# Supabase Configuration (REQUIRED for production)
# Get these from your Supabase project settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin Credentials (set these before first login)
NEXT_PUBLIC_ADMIN_USERNAME=admin
NEXT_PUBLIC_ADMIN_PASSWORD=change_this_password

# Socket.io Real-time Service
# The socket.io service runs internally on port 3003
# No configuration needed - it's handled by the gateway

# App URL (set on Vercel)
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
